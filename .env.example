# Docker compose 环境变量配置
# 复制此文件为 .env 并按需修改

# GitHub 仓库（用于拉取镜像），格式: owner/repo
GITHUB_REPO=your-org/Modex-api-doc

# 镜像标签，默认 latest
IMAGE_TAG=latest

# 文档站点端口
DOCS_PORT=3000

# ── 文档内 API / 站点地址（构建期注入文档占位符）─────────────────
# 文档正文用占位符引用这些地址，构建时替换为下方真实值。改域名只改这里。
# 必须以 VITE_ 前缀命名，VitePress(Vite) 才会加载。留空则回退到代码内默认值。

# 国内节点 API 基地址 —— 文档占位符 {{BASE_URL}}
VITE_BASE_URL=https://api.1

# 主站节点 API 基地址 —— 文档占位符 {{BASE_URL_MAIN}}
VITE_BASE_URL_MAIN=https://1

# 官网/控制台/定价等网页链接 —— 文档占位符 {{SITE_URL}}
VITE_SITE_URL=https://1

# API 开发文档站 —— 文档占位符 {{API_DOCS_URL}}
VITE_API_DOCS_URL=https://api-docs.1
